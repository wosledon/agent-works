# one-blog 生产环境配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================
DB_USER=bloguser
DB_PASSWORD=your_secure_password_here
DB_NAME=blogdb
DB_PORT=5432

# ============================================
# Redis 缓存配置 (可选)
# ============================================
REDIS_ENABLED=false
REDIS_PORT=6379

# ============================================
# JWT 认证配置
# 使用以下命令生成安全的密钥：
# openssl rand -base64 32
# ============================================
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here
JWT_ISSUER=DotnetBlog
JWT_AUDIENCE=DotnetBlogClient

# ============================================
# ASP.NET Core 配置
# ============================================
ASPNETCORE_ENVIRONMENT=Production

# ============================================
# 服务端口配置
# ============================================
BACKEND_PORT=8080
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# SSL/TLS 配置 (生产环境)
# ============================================
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
