# ==========================================
# OneReport 生产环境配置模板
# 复制为 .env 文件并修改实际值
# ==========================================

# ==========================================
# 数据库配置
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMeToSecurePassword123!
POSTGRES_DB=one_report
POSTGRES_PORT=5432

# ==========================================
# Redis 缓存配置（可选）
# ==========================================
# 如需使用 Redis，取消注释并配置
# REDIS_PORT=6379
# REDIS_URL=redis:6379

# ==========================================
# 后端 API 配置
# ==========================================
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production

# ==========================================
# 前端配置
# ==========================================
FRONTEND_PORT=80

# ==========================================
# 高级配置
# ==========================================
# 数据库连接池配置
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=100
DB_COMMAND_TIMEOUT=60

# 日志级别
LOG_LEVEL=Information
