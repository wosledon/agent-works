# ==========================================
# OneReport 开发环境配置
# ==========================================

# 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=one_report
POSTGRES_PORT=5432

# Redis 缓存配置（开发环境默认不使用）
# REDIS_PORT=6379
# REDIS_URL=redis:6379

# 后端 API 配置
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# 前端配置
FRONTEND_PORT=3000

# 日志级别
LOG_LEVEL=Debug
